rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && request.auth.token.email == "stanleyhoh79@gmail.com";
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.token.email));
    }

    function isActiveCashier() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.token.email))
        && userDoc().data.active == true;
    }

    function sameBranch(branchId) {
      return isActiveCashier() && userDoc().data.branchId == branchId;
    }

    match /users/{email} {
      allow read: if isAdmin() || (signedIn() && request.auth.token.email == email);
      allow create, update, delete: if isAdmin();
    }

    match /branches/{branchId} {
      allow read: if isActiveCashier();
      allow create, update, delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if isActiveCashier();
      allow create, delete: if isAdmin();
      allow update: if isAdmin()
        || (
          isActiveCashier()
          && request.resource.data.name == resource.data.name
          && request.resource.data.barcode == resource.data.barcode
          && request.resource.data.category == resource.data.category
          && request.resource.data.price == resource.data.price
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(["branchStock", "stock", "updatedAt", "active"])
        );
    }

    match /sales/{saleId} {
      allow read: if isAdmin() || sameBranch(resource.data.branchId);
      allow create: if isAdmin() || sameBranch(request.resource.data.branchId);
      allow update: if isAdmin() || sameBranch(resource.data.branchId);
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if isActiveCashier();
      allow create, update, delete: if isAdmin();
    }

    match /stockAdjustments/{adjustmentId} {
      allow read: if isAdmin() || sameBranch(resource.data.branchId);
      allow create: if isAdmin() || sameBranch(request.resource.data.branchId);
      allow update, delete: if isAdmin();
    }

    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin() || isActiveCashier();
      allow update, delete: if isAdmin();
    }
  }
}
